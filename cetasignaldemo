// ── listen step ──────────────────────────────────────────────────────────────
function renderListenStep() {
  document.getElementById('listen-prose').innerHTML = currentWhale.listenProse;
  drawWaveform();
  drawSpectrogram();
}

function drawWaveform() {
  const canvas = document.getElementById('waveform-canvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  const w = currentWhale;
  const samples = 400;
  const pts = [];

  for (let i = 0; i < samples; i++) {
    const t = i / samples;
    let amp = 0;
    if (w.waveType === 'rising_sweep') {
      const freq = w.freq.start + (w.freq.end - w.freq.start) * t;
      amp = Math.sin(t * freq * 0.15) * Math.sin(Math.PI * t) * 0.8;
    } else if (w.waveType === 'pulse_train') {
      const phase = t * 7;
      amp = (phase % 1 < 0.3) ? Math.sin(t * 400) * 0.7 * Math.exp(-((phase%1)*5)) : 0;
    } else if (w.waveType === 'complex_song') {
      amp = (Math.sin(t*80)*0.4 + Math.sin(t*160*(1+0.2*Math.sin(t*3)))*0.3 + Math.sin(t*40)*0.3) * Math.sin(Math.PI*t) * 0.7;
    } else if (w.waveType === 'click_train') {
      const phase = t * 30;
      amp = (phase%1 < 0.1) ? (Math.random()-0.5)*1.2 * Math.exp(-((phase%1)*20)) : (Math.random()-0.5)*0.04;
    } else if (w.waveType === 'downsweep') {
      const freq = w.freq.start + (w.freq.end - w.freq.start) * t;
      amp = Math.sin(t * freq * 0.12) * Math.pow(Math.sin(Math.PI * t * 0.7), 0.5) * 0.75;
    }
    pts.push({ x: (i/samples)*W, y: H/2 - amp*(H*0.38) });
  }

  // glow
  ctx.shadowBlur = 8;
  ctx.shadowColor = currentWhale.color.replace('var(--','').replace(')','');
  const colorMap = { 'var(--contact)':'#4EC9D4','var(--dive)':'#3A7BDB','var(--forage)':'#48D4A0','var(--navigate)':'#D4B84A','var(--broadcast)':'#C45DC8' };
  const col = colorMap[currentWhale.color] || '#4EC9D4';

  ctx.strokeStyle = col;
  ctx.lineWidth = 1.5;
  ctx.globalAlpha = 0.8;
  ctx.beginPath();
  pts.forEach((p,i) => i===0 ? ctx.moveTo(p.x,p.y) : ctx.lineTo(p.x,p.y));
  ctx.stroke();

  // centerline
  ctx.globalAlpha = 0.1;
  ctx.strokeStyle = col;
  ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(0,H/2); ctx.lineTo(W,H/2); ctx.stroke();
  ctx.globalAlpha = 1;
}

function drawSpectrogram() {
  const canvas = document.getElementById('spectrogram-canvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#030D1A';
  ctx.fillRect(0, 0, W, H);

  const w = currentWhale;
  const colorMap = { 'var(--contact)':'78,201,212','var(--dive)':'58,123,219','var(--forage)':'72,212,160','var(--navigate)':'212,184,74','var(--broadcast)':'196,93,200' };
  const rgb = colorMap[currentWhale.color] || '78,201,212';
  const maxFreq = 800;

  for (let xi = 0; xi < W; xi++) {
    const t = xi / W;
    for (let yi = 0; yi < H; yi++) {
      const freq = (1 - yi/H) * maxFreq;
      let energy = 0;

      if (w.waveType === 'rising_sweep') {
        const cf = w.freq.start + (w.freq.end - w.freq.start) * t;
        energy = Math.exp(-Math.pow((freq-cf)/30,2)) * Math.sin(Math.PI*t) * 0.9;
      } else if (w.waveType === 'pulse_train') {
        const cf = w.freq.peak;
        const inPulse = (t*7%1) < 0.28;
        energy = inPulse ? Math.exp(-Math.pow((freq-cf)/8,2)) * 0.85 : 0.01;
      } else if (w.waveType === 'complex_song') {
        const f1=200,f2=400*(1+0.15*Math.sin(t*Math.PI*4)),f3=700*(1+0.1*Math.sin(t*Math.PI*2));
        energy = (Math.exp(-Math.pow((freq-f1)/40,2))*0.5 + Math.exp(-Math.pow((freq-f2)/60,2))*0.8 + Math.exp(-Math.pow((freq-f3)/30,2))*0.4) * Math.sin(Math.PI*t*0.95);
      } else if (w.waveType === 'click_train') {
        const inClick = (t*25%1) < 0.09;
        energy = inClick ? Math.exp(-freq/600)*0.9 + Math.random()*0.1 : Math.exp(-freq/800)*0.04;
      } else if (w.waveType === 'downsweep') {
        const cf = w.freq.start + (w.freq.end - w.freq.start) * t;
        energy = Math.exp(-Math.pow((freq-cf)/15,2)) * Math.pow(Math.sin(Math.PI*t*0.75),0.5) * 0.9;
      }

      if (energy > 0.02) {
        ctx.fillStyle = `rgba(${rgb},${Math.min(energy,1)})`;
        ctx.fillRect(xi, yi, 1, 1);
      }
    }
  }

  // frequency axis labels
  ctx.fillStyle = 'rgba(58,96,112,0.8)';
  ctx.font = '9px DM Mono, monospace';
  [800,400,200,100,50].forEach(hz => {
    const y = H - (hz/maxFreq)*H;
    if (y > 0 && y < H) {
      ctx.fillText(`${hz}Hz`, 4, y-2);
      ctx.fillStyle = 'rgba(10,32,48,0.5)';
      ctx.fillRect(0, y, W, 0.5);
      ctx.fillStyle = 'rgba(58,96,112,0.8)';
    }
  });
}

// ── audio synthesis ───────────────────────────────────────────────────────────
function playSound() {
  if (isPlaying) { stopSound(); return; }
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  const w = currentWhale;
  const dur = Math.min(w.duration, 4.0);
  const sr = audioCtx.sampleRate;
  const N = Math.floor(dur * sr);
  const buf = audioCtx.createBuffer(1, N, sr);
  const data = buf.getChannelData(0);

  for (let i = 0; i < N; i++) {
    const t = i / sr;
    const tNorm = t / dur;
    let s = 0;
    if (w.waveType === 'rising_sweep') {
      const f = w.freq.start + (w.freq.end - w.freq.start) * tNorm;
      s = Math.sin(2*Math.PI*f*t) * Math.sin(Math.PI*tNorm);
    } else if (w.waveType === 'pulse_train') {
      const f = w.freq.peak * 8; // audible version
      const pulsePhase = (t * 2) % 1;
      s = pulsePhase < 0.3 ? Math.sin(2*Math.PI*f*t) * Math.exp(-pulsePhase*8) : 0;
    } else if (w.waveType === 'complex_song') {
      s = Math.sin(2*Math.PI*220*t)*0.4 + Math.sin(2*Math.PI*440*(1+0.1*Math.sin(2*Math.PI*0.5*t))*t)*0.35 + Math.sin(2*Math.PI*110*t)*0.25;
      s *= Math.sin(Math.PI*tNorm);
    } else if (w.waveType === 'click_train') {
      const clickPhase = (t*12)%1;
      s = clickPhase < 0.05 ? (Math.random()*2-1) * Math.exp(-clickPhase*60) * 0.8 : (Math.random()*2-1)*0.02;
    } else if (w.waveType === 'downsweep') {
      const f = (w.freq.start * 8) + (w.freq.end * 8 - w.freq.start * 8) * tNorm;
      s = Math.sin(2*Math.PI*f*t) * Math.pow(Math.sin(Math.PI*tNorm*0.8),0.5);
    }
    data[i] = s * 0.4;
  }

  audioSource = audioCtx.createBufferSource();
  audioSource.buffer = buf;
  audioSource.connect(audioCtx.destination);
  audioSource.start();
  isPlaying = true;

  const btn = document.getElementById('play-btn');
  btn.classList.add('playing');
  btn.querySelector('.play-icon').textContent = '■';
  document.getElementById('play-label').textContent = 'Playing...';

  audioSource.onended = stopSound;
}

function stopSound() {
  if (audioSource) { try { audioSource.stop(); } catch(e){} audioSource = null; }
  isPlaying = false;
  const btn = document.getElementById('play-btn');
  btn.classList.remove('playing');
  btn.querySelector('.play-icon').textContent = '▶';
  document.getElementById('play-label').textContent = 'Play call';
}


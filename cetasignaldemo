// ── classification ────────────────────────────────────────────────────────────
function runClassification() {
  const w = currentWhale;
  const trace = document.getElementById('rule-trace');
  trace.innerHTML = '';
  document.getElementById('result-box').classList.remove('show');

  const colorMap = {'var(--contact)':'#4EC9D4','var(--dive)':'#3A7BDB','var(--forage)':'#48D4A0','var(--navigate)':'#D4B84A','var(--broadcast)':'#C45DC8'};
  const col = colorMap[w.color] || '#4EC9D4';

  w.rules.forEach((rule, i) => {
    setTimeout(() => {
      const row = document.createElement('div');
      row.style.cssText = `display:flex;align-items:flex-start;gap:12px;padding:10px 14px;border-radius:3px;
        background:${rule.final ? `rgba(${col.replace('#','').match(/.{2}/g).map(h=>parseInt(h,16)).join(',')},0.08)` : 'rgba(7,24,40,0.6)'};
        border:1px solid ${rule.final ? col : '#0A2235'};margin-bottom:8px;
        opacity:0;transform:translateX(-10px);transition:all .3s`;
      row.innerHTML = `
        <span style="color:${rule.pass?col:'#666'};font-size:14px;margin-top:1px">${rule.pass?'✓':'✗'}</span>
        <span style="font-size:12px;color:${rule.final?col:'var(--text)'};line-height:1.6">${rule.text}</span>
      `;
      trace.appendChild(row);
      requestAnimationFrame(() => { row.style.opacity='1'; row.style.transform='translateX(0)'; });

      if (i === w.rules.length - 1) {
        setTimeout(() => showResult(w, col), 400);
      }
    }, i * 500 + 200);
  });
}

function showResult(w, col) {
  const box = document.getElementById('result-box');
  box.style.background = CLASS_BG[w.callClass] || 'rgba(78,201,212,0.06)';
  box.style.borderColor = col;

  document.getElementById('result-class').style.color = col;
  document.getElementById('result-class').textContent = `Behavioral class`;
  document.getElementById('result-name').style.color = col;
  document.getElementById('result-name').textContent = w.callClass;
  document.getElementById('result-desc').textContent = w.desc;

  const fill = document.getElementById('conf-fill');
  fill.style.background = col;
  document.getElementById('conf-label').textContent = `${w.confidence}% confidence`;

  box.classList.add('show');
  setTimeout(() => { fill.style.width = w.confidence + '%'; }, 200);
  setTimeout(() => { document.getElementById('next-3').style.display = 'block'; }, 600);
}

// ── specimen ──────────────────────────────────────────────────────────────────
function renderSpecimen() {
  const w = currentWhale;
  const now = new Date().toISOString();
  const colorMap = {'var(--contact)':'#4EC9D4','var(--dive)':'#3A7BDB','var(--forage)':'#48D4A0','var(--navigate)':'#D4B84A','var(--broadcast)':'#C45DC8'};
  const col = colorMap[w.color] || '#4EC9D4';

  const specimen = {
    id: `${w.id}_${w.callType.toLowerCase().replace(/\s/g,'_')}_001`,
    catalogId: `${w.source.split(',')[0].replace(/\s/g,'_').toUpperCase()}-${w.id.toUpperCase()}-${w.callClass}-001`,
    species: w.species,
    commonName: `${w.name} Whale`,
    callType: w.callType,
    sourceDataset: w.source,
    annotationConfidence: 'Definite',
    annotationMethod: 'Manual — Raven Pro + librosa validation',
    acousticFeatures: {
      peakFrequency_hz: w.freq.peak,
      frequencyRange_hz: [w.freq.start < w.freq.end ? w.freq.start : w.freq.end,
                          w.freq.start > w.freq.end ? w.freq.start : w.freq.end],
      duration_s: w.duration,
      freqContour: w.features.contour,
      urgencyIndex: parseFloat(w.features.urgency),
      amplitudeEnvelope: w.features.envelope,
    },
    behavioralRecord: {
      groundTruth: w.callClass,
      groundTruthMethod: 'CadenceClassifier v3.0 — constraint rules',
      description: w.desc,
    },
    extractedAt: now,
    pipelineVersion: 'cetasignal-v3.0',
  };

  const j = JSON.stringify(specimen, null, 2);
  const html = j
    .replace(/"([^"]+)":/g, `<span class="key">"$1"</span>:`)
    .replace(/: "([^"]+)"/g, `: <span class="str">"$1"</span>`)
    .replace(/: ([\d.]+)/g, `: <span class="num">$1</span>`)
    .replace(/"(CONTACT|DIVE|FORAGE|NAVIGATE|BROADCAST)"/g, `<span class="cls" style="color:${col}">"$1"</span>`)
    .replace(/[{}[\]]/g, m => `<span class="brace">${m}</span>`);

  document.getElementById('specimen-output').innerHTML = html;
}


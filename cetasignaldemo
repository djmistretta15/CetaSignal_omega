      freqRange: '14 – 28 Hz',
      duration: '3.4 s',
      contour: 'flat',
      ipi: '500 ms',
      urgency: '0.18',
      bandwidth: '14 Hz',
      envelope: 'pulse',
      repetition: '2.0 Hz',
      pulses: '7',
    },
    featureBars: { peakFrequency: 2, freqRange: 3, duration: 68, contour: 50, urgency: 18, bandwidth: 2 },
    rules: [
      { text: 'Peak frequency 20 Hz — infrasonic range', pass: true },
      { text: 'SOFAR flag: TRUE (frequency < 200 Hz)', pass: true },
      { text: 'Flat contour — directional signal, not social negotiation', pass: true },
      { text: 'Regular inter-pulse interval detected: 500 ms', pass: true },
      { text: 'Not descending — not DIVE', pass: true },

// ── journey ──────────────────────────────────────────────────────────────────
function startJourney() {
  document.getElementById('hero').style.display = 'none';
  document.getElementById('steps').style.display = 'block';
  document.getElementById('progress').style.display = 'flex';
  buildWhaleGrid();
  goStep(0);
}

function goStep(n) {
  // close previous
  if (currentStep >= 0 && currentStep !== n) {
    const prev = document.getElementById(`step-${currentStep}`);
    prev.classList.remove('active');
    if (n > currentStep) prev.classList.add('done');
    updateDot(currentStep, n > currentStep ? 'done' : '');
  }
  currentStep = n;
  const el = document.getElementById(`step-${n}`);
  el.classList.add('visible', 'active');
  el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  updateDot(n, 'active');

  if (n === 1 && currentWhale) renderListenStep();
  if (n === 3 && currentWhale) runClassification();
  if (n === 4 && currentWhale) renderSpecimen();
}

function toggleStep(n) {
  const el = document.getElementById(`step-${n}`);
  if (el.classList.contains('active')) {
    el.classList.remove('active');
  } else {
    goStep(n);
  }
}

function updateDot(n, state) {
  const d = document.getElementById(`dot-${n}`);
  if (!d) return;
  d.className = 'dot' + (state ? ' ' + state : '');
}


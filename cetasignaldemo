<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CetaSignal — Listen to the Ocean</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink:     #020810;
    --deep:    #030D1A;
    --mid:     #071828;
    --surface: #0A2235;
    --glass:   rgba(10,34,53,0.6);
    --contact:   #4EC9D4;
    --dive:      #3A7BDB;
    --forage:    #48D4A0;
    --navigate:  #D4B84A;
    --broadcast: #C45DC8;
    --text:    #A8CDD8;
    --muted:   #3A6070;
    --bright:  #C8E8F4;
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
background: var(–ink);
color: var(–text);
font-family: ‘DM Mono’, monospace;
font-size: 13px;
min-height: 100vh;
overflow-x: hidden;
}

/* ── ocean background ── */
.ocean-bg {
position: fixed; inset: 0; z-index: 0; pointer-events: none;
background: radial-gradient(ellipse 80% 60% at 50% 100%, #071828 0%, #020810 70%);
overflow: hidden;
}
.caustic {
position: absolute; inset: 0;
background-image:
radial-gradient(ellipse 3px 8px at 20% 30%, rgba(78,201,212,0.06) 0%, transparent 100%),
radial-gradient(ellipse 5px 3px at 60% 15%, rgba(78,201,212,0.04) 0%, transparent 100%),
radial-gradient(ellipse 2px 6px at 80% 60%, rgba(78,201,212,0.05) 0%, transparent 100%),
radial-gradient(ellipse 4px 4px at 35% 70%, rgba(58,123,219,0.04) 0%, transparent 100%),
radial-gradient(ellipse 6px 2px at 70% 85%, rgba(78,201,212,0.03) 0%, transparent 100%);
animation: causticShift 18s ease-in-out infinite alternate;
}
@keyframes causticShift {
0%   { transform: scale(1) translateX(0); opacity: 0.6; }
50%  { transform: scale(1.08) translateX(20px); opacity: 1; }
100% { transform: scale(0.95) translateX(-15px); opacity: 0.7; }
}

/* ── bubbles ── */
.bubble {
position: absolute; border-radius: 50%;
border: 1px solid rgba(78,201,212,0.15);
animation: rise linear infinite;
}
@keyframes rise {
0%   { transform: translateY(100vh) translateX(0); opacity: 0; }
10%  { opacity: 0.6; }
90%  { opacity: 0.2; }
100% { transform: translateY(-50px) translateX(30px); opacity: 0; }
}

/* ── layout ── */
.wrap {
position: relative; z-index: 1;
max-width: 860px; margin: 0 auto;
padding: 0 24px 80px;
}

/* ── hero ── */
.hero {
text-align: center;
padding: 80px 0 60px;
animation: fadeDown 1s ease both;
}
@keyframes fadeDown {
from { opacity: 0; transform: translateY(-20px); }
to   { opacity: 1; transform: translateY(0); }
}
.hero-eyebrow {
font-size: 10px; letter-spacing: .25em; color: var(–muted);
text-transform: uppercase; margin-bottom: 20px;
}
.hero h1 {
font-family: ‘Cormorant Garamond’, serif;
font-size: clamp(42px, 7vw, 72px);
font-weight: 300; color: var(–bright);
line-height: 1.05; margin-bottom: 16px;
}
.hero h1 em { font-style: italic; color: var(–contact); }
.hero-sub {
font-size: 13px; color: var(–muted); max-width: 420px;
margin: 0 auto 40px; line-height: 1.8;
}
.start-btn {
display: inline-block; padding: 14px 36px;
border: 1px solid var(–contact);
color: var(–contact); font-family: ‘DM Mono’, monospace;
font-size: 11px; letter-spacing: .15em; text-transform: uppercase;
cursor: pointer; background: transparent;
transition: all .3s; border-radius: 2px;
animation: pulse-border 3s ease-in-out infinite;
}
@keyframes pulse-border {
0%,100% { box-shadow: 0 0 0 0 rgba(78,201,212,0); }
50%      { box-shadow: 0 0 0 8px rgba(78,201,212,0.08); }
}
.start-btn:hover { background: rgba(78,201,212,0.08); letter-spacing: .2em; }

/* ── steps ── */
.step {
margin-bottom: 20px; border-radius: 4px;
border: 1px solid #0A2235;
background: var(–glass); backdrop-filter: blur(8px);
overflow: hidden;
opacity: 0; transform: translateY(24px);
transition: opacity .6s ease, transform .6s ease, border-color .3s;
}
.step.visible { opacity: 1; transform: translateY(0); }
.step.active  { border-color: rgba(78,201,212,0.25); }
.step.done    { border-color: rgba(78,201,212,0.12); }

.step-header {
display: flex; align-items: center; gap: 16px;
padding: 20px 24px; cursor: pointer;
transition: background .2s;
}
.step-header:hover { background: rgba(78,201,212,0.04); }

.step-num {
width: 28px; height: 28px; border-radius: 50%;
border: 1px solid var(–muted);
display: flex; align-items: center; justify-content: center;
font-size: 10px; color: var(–muted); flex-shrink: 0;
transition: all .3s;
}
.step.done .step-num  { background: var(–contact); border-color: var(–contact); color: #020810; }
.step.active .step-num { border-color: var(–contact); color: var(–contact); }

.step-title {
flex: 1;
font-family: ‘Cormorant Garamond’, serif;
font-size: 20px; font-weight: 400; color: var(–bright);
}
.step-arrow { color: var(–muted); font-size: 10px; transition: transform .3s; }
.step.active .step-arrow { transform: rotate(90deg); }

.step-body { display: none; padding: 0 24px 28px; }
.step.active .step-body { display: block; }

/* ── prose ── */
.prose {
color: var(–text); line-height: 1.9; font-size: 13px;
margin-bottom: 20px;
}
.prose strong { color: var(–bright); font-weight: 500; }

/* ── whale selector ── */
.whale-grid {
display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
gap: 10px; margin: 20px 0;
}
.whale-card {
border: 1px solid #0A2235; border-radius: 3px;
padding: 16px 14px; cursor: pointer; text-align: center;
transition: all .25s; background: rgba(3,13,26,0.6);
position: relative; overflow: hidden;
}
.whale-card::before {
content: ‘’; position: absolute; inset: 0;
opacity: 0; transition: opacity .3s;
}
.whale-card:hover::before, .whale-card.selected::before { opacity: 1; }
.whale-card.selected { border-color: rgba(78,201,212,0.5); }

.whale-emoji { font-size: 28px; margin-bottom: 8px; display: block; }
.whale-name { font-size: 10px; color: var(–muted); letter-spacing: .08em; }
.whale-species { font-family: ‘Cormorant Garamond’, serif; font-style: italic;
font-size: 12px; color: var(–text); margin-top: 3px; }

/* ── waveform ── */
.waveform-wrap {
background: var(–deep); border: 1px solid #0A2235; border-radius: 3px;
padding: 16px; margin: 16px 0; position: relative; overflow: hidden;
}
canvas.waveform {
width: 100%; height: 80px; display: block;
}
.wave-label {
font-size: 9px; color: var(–muted); letter-spacing: .15em;
margin-bottom: 8px; text-transform: uppercase;
}

/* ── play button ── */
.play-btn {
display: flex; align-items: center; gap: 10px;
padding: 10px 20px; border: 1px solid #0A2235;
background: transparent; color: var(–text);
font-family: ‘DM Mono’, monospace; font-size: 11px;
cursor: pointer; border-radius: 2px; transition: all .2s;
margin-bottom: 16px;
}
.play-btn:hover { border-color: var(–contact); color: var(–contact); }
.play-btn.playing { border-color: var(–contact); color: var(–contact); }
.play-icon { font-size: 14px; }

/* ── extraction animation ── */
.extract-btn {
width: 100%; padding: 14px;
background: transparent; border: 1px solid var(–contact);
color: var(–contact); font-family: ‘DM Mono’, monospace;
font-size: 11px; letter-spacing: .15em; text-transform: uppercase;
cursor: pointer; border-radius: 2px; transition: all .3s;
margin-top: 8px;
}
.extract-btn:hover { background: rgba(78,201,212,0.08); }
.extract-btn:disabled { opacity: 0.4; cursor: not-allowed; }

/* ── feature readout ── */
.features-grid {
display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
margin: 20px 0;
}
.feature-cell {
background: var(–deep); border: 1px solid #0A2235; border-radius: 3px;
padding: 12px 14px;
opacity: 0; transform: translateY(8px);
transition: opacity .4s ease, transform .4s ease;
}
.feature-cell.show { opacity: 1; transform: translateY(0); }
.feature-label { font-size: 9px; color: var(–muted); letter-spacing: .12em; margin-bottom: 5px; text-transform: uppercase; }
.feature-value { font-size: 18px; color: var(–bright); font-family: ‘Cormorant Garamond’, serif; }
.feature-unit  { font-size: 10px; color: var(–muted); margin-left: 4px; }
.feature-bar   { height: 2px; background: #0A2235; border-radius: 1px; margin-top: 8px; overflow: hidden; }
.feature-fill  { height: 100%; border-radius: 1px; transition: width 1s ease; }

/* ── classification result ── */
.result-box {
border-radius: 4px; padding: 28px;
text-align: center; margin: 20px 0;
opacity: 0; transform: scale(0.96);
transition: all .5s cubic-bezier(0.34, 1.56, 0.64, 1);
border: 1px solid transparent;
}
.result-box.show { opacity: 1; transform: scale(1); }

.result-class {
font-size: 11px; letter-spacing: .3em; text-transform: uppercase;
margin-bottom: 12px;
}
.result-name {
font-family: ‘Cormorant Garamond’, serif;
font-size: 52px; font-weight: 300;
line-height: 1; margin-bottom: 16px;
}
.result-desc {
font-size: 12px; color: var(–muted); line-height: 1.8;
max-width: 340px; margin: 0 auto 20px;
}
.confidence-bar {
height: 3px; background: #0A2235; border-radius: 2px;
max-width: 200px; margin: 0 auto; overflow: hidden;
}
.confidence-fill { height: 100%; border-radius: 2px; transition: width 1.2s ease; }
.confidence-label { font-size: 10px; color: var(–muted); margin-top: 8px; }

/* ── waterfall spectrogram (canvas) ── */
canvas.spectrogram { width: 100%; border-radius: 3px; display: block; }

/* ── specimen card ── */
.specimen-card {
background: var(–deep); border: 1px solid #0A2235; border-radius: 4px;
padding: 20px; font-size: 11px; font-family: ‘DM Mono’, monospace;
white-space: pre; overflow-x: auto; color: #4A8A9A;
line-height: 1.8;
}
.specimen-card .key   { color: #3A6A78; }
.specimen-card .str   { color: #7AAAB8; }
.specimen-card .num   { color: var(–navigate); }
.specimen-card .cls   { font-weight: 500; }
.specimen-card .brace { color: var(–muted); }

/* ── progress dots ── */
.progress-dots {
display: flex; gap: 8px; justify-content: center; margin-bottom: 40px;
}
.dot {
width: 6px; height: 6px; border-radius: 50%;
background: #0A2235; transition: all .3s;
}
.dot.active   { background: var(–contact); box-shadow: 0 0 8px var(–contact); }
.dot.done     { background: rgba(78,201,212,0.4); }

/* ── util ── */
.divider {
height: 1px; background: linear-gradient(to right, transparent, #0A2235, transparent);
margin: 24px 0;
}
.tag {
display: inline-block; padding: 2px 10px;
border: 1px solid currentColor; border-radius: 2px;
font-size: 9px; letter-spacing: .12em; text-transform: uppercase;
margin: 2px;
}
.loading-dots span {
animation: blink 1.4s infinite;
display: inline-block;
}
.loading-dots span:nth-child(2) { animation-delay: .2s; }
.loading-dots span:nth-child(3) { animation-delay: .4s; }
@keyframes blink { 0%,80%,100%{opacity:0} 40%{opacity:1} }

.next-btn {
display: block; width: 100%; padding: 12px;
background: transparent; border: 1px solid #0A2235;
color: var(–muted); font-family: ‘DM Mono’, monospace;
font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
cursor: pointer; border-radius: 2px; margin-top: 20px;
transition: all .25s;
}
.next-btn:hover { border-color: var(–contact); color: var(–contact); }
</style>

</head>
<body>

<div class="ocean-bg">
  <div class="caustic"></div>
</div>

<div class="wrap">

  <!-- hero -->

  <div class="hero" id="hero">
    <div class="hero-eyebrow">CetaSignal · Behavioral Acoustic Classification</div>
    <h1>Listen to<br>the <em>Ocean</em></h1>
    <p class="hero-sub">An interactive introduction to how scientists decode what whales are saying — and what CetaSignal does with it.</p>
    <button class="start-btn" onclick="startJourney()">Begin ↓</button>
  </div>

  <!-- progress -->

  <div class="progress-dots" id="progress" style="display:none">
    <div class="dot" id="dot-0"></div>
    <div class="dot" id="dot-1"></div>
    <div class="dot" id="dot-2"></div>
    <div class="dot" id="dot-3"></div>
    <div class="dot" id="dot-4"></div>
  </div>

  <!-- steps -->

  <div id="steps" style="display:none">

```

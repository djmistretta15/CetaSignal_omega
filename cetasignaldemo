    waveType: 'rising_sweep',
    freq: { start: 100, end: 250, peak: 170 },
    duration: 1.2,
    features: {
      peakFrequency: '170 Hz',
      freqRange: '100 – 250 Hz',
      duration: '1.2 s',
      contour: 'rising',
      ipi: 'none',
      urgency: '0.31',
      bandwidth: '150 Hz',
      envelope: 'sustained',
      repetition: '0.0 Hz',
      pulses: 'none',
    },
    featureBars: { peakFrequency: 12, freqRange: 18, duration: 24, contour: 80, urgency: 31, bandwidth: 15 },
    rules: [
      { text: 'Frequency contour is <strong>rising</strong>', pass: true },
      { text: 'Peak frequency 170 Hz — within mysticete social range', pass: true },
      { text: 'Duration 1.2s — consistent with contact call', pass: true },
      { text: 'No pulse train detected — not FORAGE', pass: true },
      { text: 'Not infrasonic — not NAVIGATE', pass: true },
      { text: '→ CONTACT confirmed', pass: true, final: true },
    ],
    desc: 'A position-broadcast call. The whale is announcing its location to nearby conspecifics.',
    confidence: 97,
  },
  {
    id: 'fin',
    emoji: '🐳',
    name: 'Fin Whale',
    species: 'Balaenoptera physalus',
    source: 'NOAA NEFSC, North Atlantic',
    callType: '20 Hz Pulse',
